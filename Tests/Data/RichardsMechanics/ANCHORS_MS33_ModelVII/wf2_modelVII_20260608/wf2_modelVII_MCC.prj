                   17712000  – 18144000 s: -0.4 MPa
                   18144000  – 18576000 s: -1.0 MPa
                   18576000  – 19008000 s: -2.5 MPa
                   19008000  – 19440000 s: -5.0 MPa
                   19440000  – 19872000 s: -2.5 MPa
                   19872000  – 20304000 s: -1.0 MPa
                   20304000  – 20736000 s: -0.4 MPa
            -->
            <coords>0        17280000 17712000 18144000 18576000 19008000 19440000 19872000 20304000 20736000</coords>
